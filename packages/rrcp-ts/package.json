{
  "name": "@0x0064/rrcp",
  "type": "module",
  "version": "0.0.0-alpha.0",
  "description": "rrcp - agent communication protocol",
  "author": "0x0064 (https://github.com/0x0064)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0x0064/rrcp.git",
    "directory": "packages/rrcp-ts"
  },
  "homepage": "https://github.com/0x0064/rrcp",
  "bugs": "https://github.com/0x0064/rrcp/issues",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "rrcp",
    "acp",
    "assistant",
    "agent",
    "sdk",
    "ai",
    "node"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "./dist/main.cjs",
  "module": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/main.d.ts",
        "default": "./dist/main.js"
      },
      "require": {
        "types": "./dist/main.d.cts",
        "default": "./dist/main.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "check": "tsc && biome check .",
    "check:fix": "biome check --fix .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "dependencies": {
    "postgres": "^3.4.5",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^22.9.0",
    "hono": "^4.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
